{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "skipDefaultLibCheck": true,
    "skipLibCheck": true,
    "moduleResolution": "NodeNext",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "types": ["node"]
  },
  "include": ["src/**/*", "patch.js"]
}